# ============================================================
# Variáveis de Ambiente - DaSIboard API
# ============================================================
# Copie este arquivo para .env.local e preencha com valores reais

# ─── Configuração de Ambiente ──────────────────────────────────
NODE_ENV=development
PORT=3000

# ─── Banco de Dados (Obrigatório) ─────────────────────────────
# Exemplo PostgreSQL: postgresql://user:password@localhost:5432/dasiboard_db
DATABASE_URL=postgresql://user:password@host:5432/database

# ─── Cache/Session Store (Obrigatório) ───────────────────────
# Exemplo: redis://default:password@localhost:6379
REDIS_URL=redis://localhost:6379

# ─── Autenticação JWT (Obrigatório) ────────────────────────
# Gere com: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your-super-secret-key-change-this-in-production
JWT_REFRESH_SECRET=your-refresh-secret-key-change-this-in-production

# ─── JWT Expiration Times (Opcional) ───────────────────────
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ─── CORS (Opcional) ──────────────────────────────────────────
# URL do frontend para CORS
CORS_ORIGIN=http://localhost:5173

# ─── DigitalOcean Spaces (Opcional - para upload de arquivos) ──
# Chave de acesso DO Spaces
DO_SPACES_KEY=your-spaces-key
# Secret de acesso DO Spaces
DO_SPACES_SECRET=your-spaces-secret
# Nome do bucket
DO_SPACES_BUCKET=dasiboard
# Endpoint (regiões: nyc3, sfo3, ams3, sgp1, etc.)
DO_SPACES_ENDPOINT=https://nyc3.digitaloceanspaces.com
# Endpoint público do CDN (opcional)
DO_SPACES_CDN_ENDPOINT=https://your-cdn-endpoint.com
