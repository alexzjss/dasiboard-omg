{
  "name": "dasiboard-v2",
  "private": true,
  "version": "0.0.1",
  "description": "DaSIboard v2 — Dashboard acadêmico SI-USP (monorepo)",
  "scripts": {
    "dev": "concurrently \"pnpm --filter @dasiboard/api dev\" \"pnpm --filter @dasiboard/web dev\"",
    "build": "npm run build --workspace=apps/api && npm run build --workspace=apps/web",
    "start": "pnpm --filter @dasiboard/api start",
    "db:migrate": "pnpm --filter @dasiboard/api db:migrate",
    "db:generate": "pnpm --filter @dasiboard/api db:generate",
    "db:studio": "pnpm --filter @dasiboard/api db:studio"
  },
  "workspaces": [
    "apps/web",
    "apps/api"
  ],
  "devDependencies": {
    "concurrently": "^8.2.2"
  },
  "engines": {
    "node": "20.x"
  },
  "packageManager": "pnpm@8.15.9"
}
