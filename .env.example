# App
APP_ENV=production
APP_SECRET_KEY=replace-with-64-char-random-secret
ALLOWED_ORIGINS=https://your-domain.com,https://www.your-domain.com

# Database
POSTGRES_HOST=db
POSTGRES_PORT=5432
POSTGRES_DB=dasiboard
POSTGRES_USER=dasiboard
POSTGRES_PASSWORD=replace-with-strong-db-password

# JWT
# Must be >= 32 chars and not "changeme"/"changeme-jwt-secret"
JWT_SECRET_KEY=replace-with-64-char-random-jwt-secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Calendar moderation
GLOBAL_EVENTS_KEY=replace-with-random-global-events-key

# Optional entity join keys (leave empty to keep entity open)
ENTITY_KEY_DASI=
ENTITY_KEY_EACH_IN_SHELL=
ENTITY_KEY_HYPE=
ENTITY_KEY_CONWAY=
ENTITY_KEY_CODELAB=
ENTITY_KEY_SINTESE=
ENTITY_KEY_SEMANA_SI=
ENTITY_KEY_LAB_MINAS=
ENTITY_KEY_PET_SI=
ENTITY_KEY_GRACE=
