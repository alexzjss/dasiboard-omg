// Prisma Schema — DaSIboard v2
// Banco: PostgreSQL 15

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── ENUMS ────────────────────────────────────────────────────────────────────

enum UserRole {
  GUEST
  USER
  MODERATOR
  ADMIN
}

enum EventType {
  prova
  entrega
  evento
  deadline
  apresentacao
}

enum EventStatus {
  published
  pending
  rejected
}

enum KanbanColumn {
  todo
  doing
  done
}

enum KanbanTag {
  prova
  entrega
  leitura
  projeto
  pessoal
}

enum MaterialType {
  livro
  artigo
  video
  curso
  link
  pdf
}

enum ChallengeLanguage {
  javascript
  python
  c
}

// ─── USERS ────────────────────────────────────────────────────────────────────

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String   @map("password_hash")
  displayName  String?  @map("display_name")
  photoUrl     String?  @map("photo_url")
  bio          String?
  turma        String?  // ex: "2026102"
  role         UserRole @default(USER)
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  // Relations
  events              Event[]
  kanbanCards         KanbanCard[]
  grades              UserGrade[]
  absences            UserAbsence[]
  newsletterIssues    NewsletterIssue[]
  studyMaterials      StudyMaterial[]
  challengeSubmissions ChallengeSubmission[]
  toolData            ToolData[]
  refreshTokens       RefreshToken[]

  @@map("users")
}

model RefreshToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String   @map("user_id")
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("refresh_tokens")
}

// ─── EVENTS / CALENDAR ────────────────────────────────────────────────────────

model Event {
  id          String      @id @default(uuid())
  title       String
  description String?
  date        DateTime    @db.Date
  type        EventType
  turmas      String[]    // array de códigos: ["2026102", "2026104"]
  status      EventStatus @default(pending)
  entidadeId  String?     @map("entidade_id")
  createdById String?     @map("created_by")
  createdAt   DateTime    @default(now()) @map("created_at")
  updatedAt   DateTime    @updatedAt @map("updated_at")

  entidade  Entidade? @relation(fields: [entidadeId], references: [id], onDelete: SetNull)
  createdBy User?     @relation(fields: [createdById], references: [id], onDelete: SetNull)

  @@map("events")
}

// ─── SCHEDULE ─────────────────────────────────────────────────────────────────

model ScheduleSlot {
  id          String  @id @default(uuid())
  turmaCode   String  @map("turma_code")  // ex: "2026102"
  semester    Int
  dayOfWeek   Int     @map("day_of_week") // 0=Dom ... 6=Sáb
  timeStart   String  @map("time_start")  // "07:30"
  timeEnd     String  @map("time_end")    // "09:10"
  courseName  String  @map("course_name")
  courseCode  String? @map("course_code")
  room        String?
  professor   String?
  jupiterUrl  String? @map("jupiter_url")

  @@map("schedule_slots")
}

// ─── KANBAN ───────────────────────────────────────────────────────────────────

model KanbanCard {
  id          String        @id @default(uuid())
  userId      String        @map("user_id")
  title       String
  description String?
  column      KanbanColumn  @default(todo)
  tag         KanbanTag?
  dueDate     DateTime?     @map("due_date") @db.Date
  position    Int           @default(0)
  createdAt   DateTime      @default(now()) @map("created_at")
  updatedAt   DateTime      @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("kanban_cards")
}

// ─── NOTAS & GPA ──────────────────────────────────────────────────────────────

model UserGrade {
  id           String   @id @default(uuid())
  userId       String   @map("user_id")
  disciplineId String   @map("discipline_id")
  grade        Decimal? @db.Decimal(4, 2)
  credits      Int      @default(4)
  semester     Int
  updatedAt    DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, disciplineId])
  @@map("user_grades")
}

// ─── FALTAS ───────────────────────────────────────────────────────────────────

model UserAbsence {
  id              String   @id @default(uuid())
  userId          String   @map("user_id")
  disciplineCode  String   @map("discipline_code")
  disciplineName  String   @map("discipline_name")
  totalClasses    Int      @default(0) @map("total_classes")
  absences        Int      @default(0)
  updatedAt       DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, disciplineCode])
  @@map("user_absences")
}

// ─── NEWSLETTER ───────────────────────────────────────────────────────────────

model NewsletterIssue {
  id          String   @id @default(uuid())
  entidadeId  String?  @map("entidade_id") // null = newsletter geral do dashboard
  title       String
  summary     String
  content     String
  publishedAt DateTime @default(now()) @map("published_at")
  createdById String?  @map("created_by")
  createdAt   DateTime @default(now()) @map("created_at")

  entidade  Entidade? @relation(fields: [entidadeId], references: [id], onDelete: SetNull)
  createdBy User?     @relation(fields: [createdById], references: [id], onDelete: SetNull)

  @@map("newsletter_issues")
}

// ─── DOCENTES ─────────────────────────────────────────────────────────────────

model Docente {
  id       String  @id @default(uuid())
  name     String
  title    String?
  area     String?
  email    String?
  photoUrl String? @map("photo_url")
  lattes   String?
  site     String?
  active   Boolean @default(true)

  @@map("docentes")
}

// ─── ESTUDOS ──────────────────────────────────────────────────────────────────

model StudyMaterial {
  id          String       @id @default(uuid())
  title       String
  type        MaterialType
  area        String?
  discipline  String?
  author      String?
  url         String?
  fileUrl     String?      @map("file_url") // PDF no DO Spaces
  tags        String[]
  createdById String?      @map("created_by")
  createdAt   DateTime     @default(now()) @map("created_at")

  createdBy User? @relation(fields: [createdById], references: [id], onDelete: SetNull)

  @@map("study_materials")
}

// ─── ENTIDADES ────────────────────────────────────────────────────────────────

model Entidade {
  id             String  @id @default(uuid())
  slug           String  @unique
  name           String
  fullName       String? @map("full_name")
  type           String  // "Diretório Acadêmico", "Liga", etc.
  description    String?
  colorPrimary   String? @map("color_primary")
  colorSecondary String? @map("color_secondary")
  emoji          String?
  email          String?
  links          Json    @default("[]") // [{label, url, icon}]
  active         Boolean @default(true)

  events          Event[]
  newsletterIssues NewsletterIssue[]

  @@map("entidades")
}

// ─── DESAFIOS ─────────────────────────────────────────────────────────────────

model ChallengeSubmission {
  id          String            @id @default(uuid())
  userId      String            @map("user_id")
  challengeId String            @map("challenge_id")
  lang        ChallengeLanguage
  code        String
  passed      Boolean
  testResults Json              @map("test_results") // [{ok, input, expected, got}]
  submittedAt DateTime          @default(now()) @map("submitted_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("challenge_submissions")
}

// ─── TOOL DATA (Notas Rápidas, Flashcards) ────────────────────────────────────

model ToolData {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  toolKey   String   @map("tool_key") // "notes", "flashcards"
  data      Json
  updatedAt DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, toolKey])
  @@map("tool_data")
}
